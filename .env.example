# Quranify - Environment Variables Example
# Copy this file to .env.local and fill in your actual values

# Quran Foundation API (quran.com) — exposed in client bundle (read-only Quran data)
VITE_QURAN_CLIENT_ID=your-client-id-here
VITE_QURAN_CLIENT_SECRET=your-client-secret-here
# Pre-production: https://prelive-oauth2.quran.foundation
# Production:     https://oauth2.quran.foundation
VITE_QURAN_OAUTH_ENDPOINT=https://oauth2.quran.foundation
# VITE_QURAN_CONTENT_BASE_URL=  # optional — only needed if using a non-production content API
